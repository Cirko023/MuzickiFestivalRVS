@model PrezentacioniSloj.PrezentacionaLogika.ViewModeli.RegistracijaViewModel
@{
    ViewData["Title"] = "Registracija";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-4">Registracija korisnika</h2>
        <form asp-action="Registracija" method="post" id="forma-registracija">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="KorisnickoIme" class="form-label"></label>
                <input asp-for="KorisnickoIme" class="form-control" id="korisnicko-ime" />
                <span asp-validation-for="KorisnickoIme" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" id="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Lozinka" class="form-label"></label>
                <input asp-for="Lozinka" class="form-control" id="lozinka" />
                <span asp-validation-for="Lozinka" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Registruj se</button>
            <a asp-action="Prijava" class="btn btn-link">Nazad na prijavu</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
