@model PrezentacioniSloj.PrezentacionaLogika.ViewModeli.PrijavaViewModel
@{
    ViewData["Title"] = "Prijava";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-4">Prijava korisnika</h2>
        <form asp-action="Prijava" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="KorisnickoIme" class="form-label"></label>
                <input asp-for="KorisnickoIme" class="form-control" id="korisnicko-ime" />
                <span asp-validation-for="KorisnickoIme" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Lozinka" class="form-label"></label>
                <input asp-for="Lozinka" class="form-control" />
                <span asp-validation-for="Lozinka" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Prijavi se</button>
            <a asp-action="Registracija" class="btn btn-link">Registracija</a>
        </form>
        <div class="alert alert-info mt-3">
            Test nalog: <strong>admin</strong> / <strong>admin</strong>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
