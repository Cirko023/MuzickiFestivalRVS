<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Muzički Festival</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/stil.css" asp-append-version="true" />
</head>
<body>
    <header class="d-print-none">
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Zapisnik" asp-action="Spisak">Muzički Festival</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navigacija">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navigacija">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Zapisnik" asp-action="Spisak">Zapisnici o koncertima</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Zapisnik" asp-action="Unos">Novi zapisnik</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (Context.Session.GetString("KorisnickoIme") != null)
                        {
                            <li class="nav-item">
                                <span class="nav-link">@Context.Session.GetString("KorisnickoIme")</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Nalog" asp-action="Odjava">Odjava</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Nalog" asp-action="Prijava">Prijava</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Nalog" asp-action="Registracija">Registracija</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted d-print-none py-3">
        <div class="mt-5 pt-3 text-center text-white-50 border-top border-secondary">&copy; 2026 - Evidencija koncerta na muzičkom festivalu</div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/validacije.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
