@model PrezentacioniSloj.PrezentacionaLogika.ViewModeli.ZapisnikViewModel
@{
    ViewData["Title"] = "Spisak zapisnika";
    var zapisnici = ViewBag.Zapisnici as List<SlojServisa.KlaseDTO.ZapisnikKoncertaDTO> ?? new();
}

@if (ViewBag.UkupnoZapisnika != null)
{
    <div class="alert alert-dark" role="alert">
        Ukupan broj zapisnika (stored procedura): <strong>@ViewBag.UkupnoZapisnika</strong>
    </div>
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-light">Pregled zapisnika o koncertima</h2>
        <a asp-action="Unos" class="btn btn-success">+ Novi zapisnik</a>
    </div>

    <div class="card bg-dark border-secondary mb-4">
        <div class="card-header bg-secondary bg-opacity-25 text-white border-secondary">
            <strong>Filter pretrage</strong>
        </div>
        <div class="card-body">
            <form method="get" asp-action="Spisak" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label text-white-50">Datum od</label>
                    <input type="date" class="form-control bg-dark text-white border-secondary" name="DatumOd" value="@Model?.DatumOd?.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-4">
                    <label class="form-label text-white-50">Datum do</label>
                    <input type="date" class="form-control bg-dark text-white border-secondary" name="DatumDo" value="@Model?.DatumDo?.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-4">
                    <label class="form-label text-white-50">Izvođač</label>
                    <select class="form-select bg-dark text-white border-secondary" name="FilterIzvodjacId" asp-items="@Model?.Izvodjaci">
                        <option value="">Svi izvođači</option>
                    </select>
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill">Filtriraj</button>
                    <a asp-action="Spisak" class="btn btn-outline-light flex-fill">Poništi</a>
                    <a asp-action="Stampa" asp-route-datumOd="@Model?.DatumOd" asp-route-datumDo="@Model?.DatumDo" asp-route-izvodjacId="@Model?.FilterIzvodjacId" class="btn btn-outline-light flex-fill">Štampa</a>
                </div>
            </form>
        </div>
    </div>

    @if (!zapisnici.Any())
    {
        <div class="alert alert-secondary text-center">
            Nema zapisnika za prikaz.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-bordered border-secondary align-middle">
                <thead class="table-secondary text-dark">
                    <tr>
                        <th>Datum</th>
                        <th>Festival</th>
                        <th>Izvođač</th>
                        <th>Bina</th>
                        <th>Popust (%)</th>
                        <th>Kotizacija (RSD)</th>
                        <th style="width: 320px;">Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var z in zapisnici)
                    {
                        <tr>
                            <td>@z.DatumKoncerta.ToString("dd.MM.yyyy")</td>
                            <td>@z.NazivFestivala</td>
                            <td>@z.NazivBenda</td>
                            <td>@z.Bina</td>
                            <td>@z.PopustProcenat.ToString("0.##")%</td>
                            <td>@z.KotizacijaSaPopustom.ToString("N0")</td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                        Akcije
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-dark">
                                        <li><a class="dropdown-item" asp-action="Detalji" asp-route-id="@z.ZapisnikID">Detalji</a></li>
                                        <li><a class="dropdown-item" asp-action="Izmena" asp-route-id="@z.ZapisnikID">Izmena</a></li>
                                        <li><form asp-action="Obrisi" asp-route-id="@z.ZapisnikID" method="post" onsubmit="return confirm('Obrisati?')"><button class="dropdown-item text-danger">Obriši</button></form></li>
                                        <li><a class="dropdown-item" asp-action="Stampa" asp-route-id="@z.ZapisnikID">Štampa</a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
